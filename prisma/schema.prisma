datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

// ─── Cache Layer ────────────────────────────

model ApiCache {
  id        String   @id @default(uuid())
  cacheKey  String   @unique
  endpoint  String
  response  String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─── Auth ───────────────────────────────────

model GoogleToken {
  id           String   @id @default(uuid())
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Multi-Brand ────────────────────────────

// ─── Users & Auth ────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("user") // admin | user
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     Session[]
  brandMembers BrandMember[]
  activityLogs ActivityLog[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BrandMember {
  id      String @id @default(uuid())
  userId  String
  brandId String
  role    String @default("viewer") // viewer | editor | analyst

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([userId, brandId])
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  brandId   String?
  action    String   // login, run_diagnostic, generate_content_map, run_optimize, etc.
  details   String?  // JSON with extra context
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Brand ───────────────────────────────────

model Brand {
  id          String   @id @default(uuid())
  name        String
  domain      String
  gscProperty String?
  vertical    String?
  description String?
  createdBy   String?  // userId of creator
  // Brand Intelligence (AI-generated, editable)
  coreProducts       String?
  notBrand           String?
  targetAudience     String?
  competitors        String?
  contentTopics      String?
  sitePages          String?
  brandIntelligence  String?
  targetKeywords     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  keywords       Keyword[]
  diagnostics    Diagnostic[]
  contentMaps    ContentMap[]
  serpSnapshots   SerpSnapshot[]
  serpAnalyses    SerpAnalysis[]
  pageAudits     PageAudit[]
  aoeStrategies  AoeStrategy[]
  performanceSnapshots PerformanceSnapshot[]
  members        BrandMember[]
}

// ─── Page Audit (Optimize section) ──────────

model PageAudit {
  id              String   @id @default(uuid())
  brandId         String
  status          String   @default("pending")
  pipelineLog     String   @default("[]")
  auditData       String?  // JSON: PageAuditData[]
  quickWins       String?  // JSON: QuickWin[]
  recommendations String?  // JSON: Recommendation[]
  summary         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

// ─── SERP Analysis (independent from diagnostic) ──

model SerpAnalysis {
  id              String   @id @default(uuid())
  brandId         String
  status          String   @default("pending")
  pipelineLog     String   @default("[]")
  // Results stored as JSON
  serpPerformance String?  // Our top keywords with SERP feature ownership
  competitorGap   String?  // Keywords competitors rank for, we don't (ICP filtered)
  icpAlignment    String?  // Our keywords classified by ICP alignment
  opportunities   String?  // Prioritized action items
  summary         String?  // AI summary
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

// ─── Diagnostic (Fase 1) ───────────────────

model Diagnostic {
  id               String   @id @default(uuid())
  brandId          String
  name             String
  status           String   @default("pending")
  pipelineLog      String   @default("[]")
  currentStructure String?
  gaps             String?
  cannibalization  String?
  summary          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

// ─── Keywords ───────────────────────────────

model Keyword {
  id               String   @id @default(uuid())
  brandId          String
  query            String
  clicks           Int      @default(0)
  impressions      Int      @default(0)
  ctr              Float    @default(0)
  position         Float    @default(0)
  pageUrl          String?
  searchVolume     Int?
  kd               Int?
  cpc              Float?
  competition      Float?
  competitionLevel String?
  intent           String?
  serpFeatures     String?
  source           String   @default("gsc")
  createdAt        DateTime @default(now())

  brand         Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  contentPieces ContentPiece[]
  serpResults    SerpResult[]

  @@unique([brandId, query])
}

// ─── SERP Analysis ──────────────────────────

model SerpSnapshot {
  id        String       @id @default(uuid())
  brandId   String
  name      String
  createdAt DateTime     @default(now())
  results   SerpResult[]

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

model SerpResult {
  id                  String   @id @default(uuid())
  snapshotId          String
  keywordId           String?
  hasFeaturedSnippet  Boolean  @default(false)
  ownsFeaturedSnippet Boolean  @default(false)
  hasPaa              Boolean  @default(false)
  paaQuestions        String   @default("[]")
  hasKnowledgePanel   Boolean  @default(false)
  hasVideoResults     Boolean  @default(false)
  hasLocalPack        Boolean  @default(false)
  hasImagePack        Boolean  @default(false)
  hasSitelinks        Boolean  @default(false)
  hasAiOverview       Boolean  @default(false)
  topCompetitors      String   @default("[]")
  serpFeaturesList     String   @default("[]")
  rawResponse         String?
  createdAt           DateTime @default(now())

  snapshot SerpSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  keyword  Keyword?     @relation(fields: [keywordId], references: [id], onDelete: SetNull)
}

// ─── Content Map ────────────────────────────

model ContentMap {
  id           String   @id @default(uuid())
  brandId      String
  diagnosticId String?
  name         String
  quarter      String?  // e.g. "Q2 2026"
  status       String   @default("pending")
  pipelineLog  String   @default("[]")
  // Content map data (JSON)
  keywordPool  String?  // Keyword pool JSON — saved for reuse
  mapData      String?  // Full content map pieces JSON
  briefs       String?  // Content briefs JSON
  reviewResult String?  // Quality review JSON
  summary      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  brand             Brand              @relation(fields: [brandId], references: [id], onDelete: Cascade)
  contentPieces     ContentPiece[]
  pageOptimizations PageOptimization[]
}

model ContentPiece {
  id               String   @id @default(uuid())
  contentMapId     String
  keywordId        String?
  pillarName       String
  pillarKeyword    String
  clusterName      String
  clusterKeyword   String
  intent           String
  contentType      String
  category         String
  kd               Int?
  competition      String?
  cpc              Float?
  searchVolume     Int?
  title            String
  description      String
  reasoning        String
  paaQuestions     String   @default("[]")
  serpElements     String   @default("[]")
  opportunityScore Float    @default(0)
  priority         String   @default("medium")
  status           String   @default("not_started")
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())

  contentMap ContentMap @relation(fields: [contentMapId], references: [id], onDelete: Cascade)
  keyword    Keyword?   @relation(fields: [keywordId], references: [id], onDelete: SetNull)
}

// ─── AOE Strategy ───────────────────────────

model AoeStrategy {
  id        String            @id @default(uuid())
  brandId   String
  name      String
  month     Int
  year      Int
  summary   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  items     AoeStrategyItem[]

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

model AoeStrategyItem {
  id                 String   @id @default(uuid())
  strategyId         String
  targetQuery        String
  targetEngine       String
  currentPresence    String   @default("none")
  currentSnippet     String?
  recommendedContent String
  contentFormat      String
  optimizationTips   String   @default("[]")
  estimatedImpact    String   @default("medium")
  priority           String   @default("medium")
  status             String   @default("not_started")
  createdAt          DateTime @default(now())

  strategy AoeStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
}

// ─── Performance Snapshots ──────────────────

model PerformanceSnapshot {
  id                 String   @id @default(uuid())
  brandId            String
  weekOf             String                          // Monday date: "2026-04-06"
  // Aggregate metrics
  totalClicks        Int      @default(0)
  totalImpressions   Int      @default(0)
  avgCtr             Float    @default(0)
  avgPosition        Float    @default(0)
  // Distribution
  top3Count          Int      @default(0)
  top10Count         Int      @default(0)
  top20Count         Int      @default(0)
  top50Count         Int      @default(0)
  totalKeywords      Int      @default(0)
  // Value
  trafficValue       Float    @default(0)
  // Keyword positions (JSON: top 200 keywords with positions)
  keywordPositions   String   @default("[]")         // JSON: [{ query, position, clicks, impressions, page }]
  // Content impact
  contentPublished   Int      @default(0)
  contentRanking     Int      @default(0)
  aeoActionsDone     Int      @default(0)
  aeoActionsTotal    Int      @default(0)
  createdAt          DateTime @default(now())

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, weekOf])
}

// ─── Page Optimization ──────────────────────

model PageOptimization {
  id                   String   @id @default(uuid())
  contentMapId         String
  pageUrl              String
  pageTitle            String?
  primaryKeyword       String
  relatedKeywords      String   @default("[]")
  currentPosition      Float
  currentClicks        Int      @default(0)
  currentImpressions   Int      @default(0)
  currentCtr           Float    @default(0)
  potentialPosition    Float?
  potentialTrafficGain Int?
  issueType            String
  diagnosis            String
  recommendations      String   @default("[]")
  reasoning            String
  difficulty           String   @default("medium")
  impact               String   @default("medium")
  isQuickWin           Boolean  @default(false)
  priority             String   @default("medium")
  status               String   @default("not_started")
  createdAt            DateTime @default(now())

  contentMap ContentMap @relation(fields: [contentMapId], references: [id], onDelete: Cascade)
}
